# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit your real key.

# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Get your key at https://outscraper.com/profile/ → API Key
OUTSCRAPER_API_KEY=your_outscraper_key_here

# Optional: override the default model
# Default: google/gemini-2.0-flash-exp:free
# Alternatives: deepseek/deepseek-chat:free  |  meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Your deployed URL (shown in OpenRouter request headers for analytics)
SITE_URL=https://your-app.railway.app

# Port (Railway sets this automatically — do not change for production)
PORT=3000

# Postgres connection string (Railway injects this automatically when a
# Postgres service is attached via a variable reference).
DATABASE_URL=

# Random secret used to sign session cookies. Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Set to "true" only on the customer-facing deployment once Square is wired
# up (see the pricing doc) — gates report generation behind an active
# subscription/trial. Leave "false" on internal/demo instances.
BILLING_ENABLED=false

# Square billing (only needed when BILLING_ENABLED=true). Create an
# application at https://developer.squareup.com/apps — start with the
# Sandbox Application ID/Access Token to test, switch to production
# credentials + SQUARE_ENVIRONMENT=production when going live.
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_CURRENCY=AUD

# Signature key from the webhook subscription created for
# https://<your-domain>/api/billing/webhook (Square Developer Dashboard →
# your app → Webhooks, or via the Webhooks API).
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Resend (https://resend.com/api-keys) — powers the "Email to Client"
# button and per-business batch emails. Without a verified sending domain,
# Resend's free tier only delivers to the account owner's own email —
# verify a domain in the Resend dashboard to send to arbitrary clients.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
