# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit your real key.

# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: override the default model
# Default is google/gemini-2.0-flash-exp:free
# Other free options: deepseek/deepseek-chat:free  |  meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Your deployed URL (used in OpenRouter HTTP-Referer header for analytics)
SITE_URL=https://your-app.railway.app

# Port (Railway sets this automatically)
PORT=3000
